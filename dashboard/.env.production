# Production API base for the hosted dashboard (Vercel).
# NEXT_PUBLIC_* is embedded in the client bundle and is PUBLIC by design — only a
# URL, never a secret. Replace with your actual Render URL after the API deploys,
# OR set it in the Vercel project's Environment Variables (which overrides this).
NEXT_PUBLIC_API_URL=https://purplle-store-intel-api.onrender.com
